            "image_pos": "below_description",
            "author": "<strong>Camila R.<\/strong> — Medellín"
          }
        },
        "column_xzd6Uc": {
          "type": "column",
          "settings": {
            "title": "Daniela P.",
            "text": "<p>Bonita pulsera, el trébol de cuatro hojas se ve delicado y elegante. El envío tardó unos días más de lo esperado pero llegó en perfecto estado.<\/p>",
            "image": "shopify:\/\/shop_images\/3.png",
