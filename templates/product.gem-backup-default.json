        "column_PXefCU": {
          "type": "column",
          "settings": {
            "title": "Camila R.",
            "text": "<p>Me la regalé a mí misma y no me arrepiento. Se ve muy fina y la calidad es buena para el precio. El pago contra entrega me dio mucha confianza para comprar.<\/p>",
