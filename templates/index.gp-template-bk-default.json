ing_pL7wJE":{"settings":{"heading":"Únete a Nuestra Comunidad","heading_size":"h1"},"type":"heading"},"paragraph_Qc7xgi":{"settings":{"text":"\u003cp\u003eRecibe primero las nuevas colecciones y ofertas exclusivas para suscriptoras\u003c/p\u003e"},"type":"paragraph"}},"name":"t:sections.newsletter.presets.name","settings":{"color_scheme":"scheme-2","full_width":true,"padding_bottom":100,"padding_top":100},"type":"newsletter"},"rich_text_H7a4nF":{"block_order":["heading_kqNdfD","text_9fyDyB","button_4exxC9"],"blocks":{"button_4exxC9":{"disabled":true,"settings":{"button_label":"Button label","button_label_2":"","button_link":"","button_link_2":"","button_style_secondary":false,"button_style_secondary_2":false},"type":"button"},"heading_kqNdfD":{"settings":{"heading":"Hecho con Amor y Precisión","heading_size":"h1"},"type":"heading"},"text_9fyDyB":{"settings":{"text":"\u003cp\u003eCada pieza de nuestra colección es seleccionada con cuidado, combinando materiales de alta calidad con diseños atemporales que realzan tu belleza natural.\u003c/p\u003e"},"type":"text"}},"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"scheme-1","content_alignment":"center","desktop_content_position":"center","full_width":true,"padding_bottom":80,"padding_top":80},"type":"rich-text"},"rich_text_xFfiXb":{"block_order":["heading_GiEajR","text_dEhEd3"],"blocks":{"heading_GiEajR":{"settings":{"heading":"La Historia de Vexora Jewelry","heading_size":"h1"},"type":"heading"},"text_dEhEd3":{"settings":{"text":"\u003cp\u003eEn Vexora Jewelry, cada pieza cuenta una historia de elegancia y distinción. Creemos que la joyería no es solo un accesorio, sino una expresión de tu personalidad y estilo de vida.\u003c/p\u003e\u003cp\u003eDesde nuestros inicios, nos hemos comprometido a ofrecer diseños minimalistas y sofisticados que trascienden las tendencias. Utilizamos solo los mejores materiales: acero inoxidable quirurgico, baño de oro 18k, piedras naturales y cristales Swarovski certificados.\u003c/p\u003e\u003cp\u003eCada pieza es creada con pasión y dedicación, reflejando nuestro compromiso inquebrantable con la calidad y la excelencia. Porque mereces joyería que te haga sentir extraordinaria.\u003c/p\u003e"},"type":"text"}},"settings":{"color_scheme":"scheme-1","content_alignment":"center","desktop_content_position":"center","full_width":true,"padding_bottom":60,"padding_top":60},"type":"rich-text"},"section_divider_qbL6Uj":{"settings":{"background_color":"#ffffff","flip_horizontal":false,"flip_vertical":false,"padding_bottom":0,"padding_top":0,"shape":"waves_3","shape_color":"#1a1a1a"},"type":"section-divider"},"testimonials_dngRaR":{"block_order":["column_YgYXe4","column_4P8QAn","column_hUznym"],"blocks":{"column_4P8QAn":{"settings":{"author":"\u003cem\u003e\u003cstrong\u003eDaniela Martínez\u003c/strong\u003e\u003c/em\u003eMedellín","image_pos":"below_description","text":"\u003cp\u003e\"Los aretes son hermosos, exactamente como en las fotos. El empaque es muy elegante, perfecto para regalar. ¡Volveré a comprar!\"\u003c/p\u003e","title":"Perfecto para regalar"},"type":"column"},"column_YgYXe4":{"settings":{"author":"\u003cem\u003e\u003cstrong\u003eValentina Gómez\u003c/strong\u003e\u003c/em\u003eBogotá","image_pos":"below_description","text":"\u003cp\u003e\"¡Me encantó mi pulsera de Vexora! La calidad es increíble y llegó súper rápido. Sin duda la mejor joyería que he comprado en Colombia. 💛\"\u003c/p\u003e","title":"¡Me encantó!"},"type":"column"},"column_hUznym":{"settings":{"author":"\u003cem\u003e\u003cstrong\u003eCamila Rodríguez\u003c/strong\u003e\u003c/em\u003eCali","image_pos":"below_description","text":"\u003cp\u003e\"Excelente atención y producto de lujo a un precio justo. Mi collar de Vexora recibe cumplidos cada vez que lo uso. ¡100% recomendado!\"\u003c/p\u003e","title":"100% recomendado"},"type":"column"}},"settings":{"background_color":"#f5f0e8","gap":20,"padding_bottom":80,"padding_top":80,"show_quotes":true,"show_stars":true,"stars_color":"#c9a84c","testimonials_per_row":3,"title":"Lo que dicen nuestras clientas"},"type":"testimonials"}}}