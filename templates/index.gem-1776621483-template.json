    "testimonials_dngRaR": {
      "type": "testimonials",
      "blocks": {
        "column_YgYXe4": {
          "type": "column",
          "settings": {
            "title": "¡Me encantó!",
            "text": "<p>\"¡Me encantó mi pulsera de Vexora! La calidad es increíble y llegó súper rápido. Sin duda la mejor joyería que he comprado en Colombia. 💛\"<\/p>",
            "image_pos": "below_description",
            "author": "<em><strong>Valentina Gómez<\/strong><\/em>Bogotá"
          }
        },
        "column_4P8QAn": {
          "type": "column",
          "settings": {
            "title": "Perfecto para regalar",
            "text": "<p>\"Los aretes son hermosos, exactamente como en las fotos. El empaque es muy elegante, perfecto para regalar. ¡Volveré a comprar!\"<\/p>",
            "image_pos": "below_description",
            "author": "<em><strong>Daniela Martínez<\/strong><\/em>Medellín"
          }
        },
        "column_hUznym": {
          "type": "column",
          "settings": {
            "title": "100% recomendado",
            "text": "<p>\"Excelente atención y producto de lujo a un precio justo. Mi collar de Vexora recibe cumplidos cada vez que lo uso. ¡100% recomendado!\"<\/p>",
            "image_pos": "below_description",
            "author": "<em><strong>Camila Rodríguez<\/strong><\/em>Cali"
          }
        }
      },
      "block_order": [
        "column_YgYXe4",
